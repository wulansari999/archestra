/playwright/
.playwright-mcp/
.playwright-cli/
playwright-report/

# Dolt database files (added by bd init)
.dolt/
*.db

# Local planning specs
specs/

# project-local binaries bootstrapped by dev scripts (e.g., dagger CLI)
dev/bin/

# local kubeconfigs (may embed live ServiceAccount tokens) — never commit
*.kubeconfig
