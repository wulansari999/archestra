{
  "name": "archestra-platform",
  "version": "1.2.69",
  "description": "Enterprise MCP platform",
  "author": "Archestra",
  "engines": {
    "node": ">=18.0.0 <25.0.0"
  },
  "scripts": {
    "prepare": "cd .. && husky platform/.husky || true",
    "ci:check": "turbo check:ci",
    "commit:check": "turbo check:commit",
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "lint:fix:unsafe": "turbo lint:fix:unsafe",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "knip": "turbo knip",
    "test:e2e": "turbo test:e2e",
    "test:e2e:ui": "turbo test:e2e:ui",
    "test:integration": "turbo test:integration",
    "test:integration:ui": "turbo test:integration:ui",
    "check:ci": "turbo check:ci",
    "license-check": "tsx standalone-scripts/license-check.ts",
    "codegen": "CODEGEN=true turbo codegen && python3 dev/grafana/generate-pg-dashboard-variants.py",
    "cleanup:dev:caches": "tsx standalone-scripts/cleanup-dev-caches.ts",
    "skills:index": "tsx standalone-scripts/generate-skill-index.ts",
    "db:generate": "turbo db:generate --ui=tui",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "turbo db:studio",
    "db:seed:mock-data": "turbo db:seed:mock-data",
    "cleanup:dev:k8s": "kubectl delete namespace archestra-dev",
    "dev:stack:up": "scripts/dev-stack.sh up",
    "dev:stack:down": "scripts/dev-stack.sh down",
    "dev:stack:hydrate": "scripts/dev-stack.sh hydrate",
    "dev:stack:status": "scripts/dev-stack.sh status"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "turbo": "^2.9.14"
  },
  "packageManager": "pnpm@11.5.2",
  "dependencies": {
    "croner": "^10.0.1"
  }
}
