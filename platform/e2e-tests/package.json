{
  "name": "@e2e-tests",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "scripts": {
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "lint:fix:unsafe": "biome check --write --unsafe",
    "type-check": "tsgo --noEmit",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:ui": "pnpm exec playwright test --ui",
    "test:e2e:report": "pnpm exec playwright show-report",
    "check:ci": "concurrently --kill-others-on-fail --group --names type-check,knip,biome 'pnpm type-check' 'pnpm knip' 'biome ci'",
    "check:commit": "concurrently --kill-others-on-fail --group --names type-check,knip,biome 'pnpm type-check' 'pnpm knip' 'biome ci'",
    "knip": "knip"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@archestra/shared": "workspace:*",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "catalog:",
    "knip": "^5.85.0",
    "typescript": "catalog:"
  }
}
